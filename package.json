{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/api-admin",
        "apps/mobile-client"
    ],
    "scripts": {
        "api:build": "npm --prefix apps/api-admin run build",
        "api:dev": "npm --prefix apps/api-admin run dev",
        "build": "npm run api:build && npm run mobile:build",
        "dev:api": "npm run api:dev",
        "dev:mobile": "npm run mobile:dev",
        "memory:architecture": "npx --yes codebase-memory-mcp@0.8.1 cli get_architecture '{\"project\":\"Users-andrejprus-Herd-mobile-lara\"}'",
        "memory:config": "npx --yes codebase-memory-mcp@0.8.1 config list",
        "memory:index": "npx --yes codebase-memory-mcp@0.8.1 cli index_repository '{\"repo_path\":\"$PWD\"}'",
        "memory:projects": "npx --yes codebase-memory-mcp@0.8.1 cli list_projects '{}'",
        "memory:status": "npx --yes codebase-memory-mcp@0.8.1 cli index_status '{\"project\":\"Users-andrejprus-Herd-mobile-lara\"}'",
        "mobile:build": "npm --prefix apps/mobile-client run build",
        "mobile:dev": "npm --prefix apps/mobile-client run dev"
    }
}
