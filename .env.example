APP_NAME="Mobile Lara"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://mobile-lara.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_VERSION_CODE=1
NATIVEPHP_APP_NAME="Mobile Lara"
NATIVEPHP_APP_ID=com.example.mobilelara
NATIVEPHP_IOS_BUNDLE_IDENTIFIER=com.example.mobilelara
NATIVEPHP_ANDROID_PACKAGE=com.example.mobilelara
NATIVEPHP_APP_ICON=public/icon.png
NATIVEPHP_DEEPLINK_SCHEME=mobilelara
NATIVEPHP_DEEPLINK_HOST=mobile-lara.test
NATIVEPHP_START_URL=/
NATIVEPHP_DEVELOPMENT_TEAM=
NATIVEPHP_ANDROID_COLOR_PRIMARY="#04ABA6"
NATIVEPHP_ANDROID_COLOR_PRIMARY_NIGHT="#FFFFFF"
NATIVEPHP_ANDROID_COLOR_ON_PRIMARY="#FFFFFF"
NATIVEPHP_HTTP_PORT=3000
NATIVEPHP_WS_PORT=8081
NATIVEPHP_SERVICE_NAME="Mobile Lara"
NATIVEPHP_OPEN_BROWSER=false

MOBILE_AUTH_TOKEN_STORE=native_secure_storage
MOBILE_AUTH_SECURE_KEY_PREFIX=mobile_auth
MOBILE_AUTH_ACCESS_TOKEN_TTL_MINUTES=15
MOBILE_AUTH_REFRESH_TOKEN_TTL_MINUTES=43200
MOBILE_AUTH_REVOCATION_TTL_MINUTES=43200

VITE_APP_NAME="${APP_NAME}"
