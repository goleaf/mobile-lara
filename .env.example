# Mobile Lara monorepo root
#
# The repository root is not a Laravel runtime. Configure the two applications
# in their own folders:
#
# - apps/api-admin/.env.example      Admin panel + versioned mobile API
# - apps/mobile-client/.env.example  NativePHP mobile client
#
# Typical local URLs:
# API_ADMIN_APP_URL=http://api-admin.test
# MOBILE_CLIENT_APP_URL=http://mobile-client.test
#
# The mobile app should point at the Admin/API service through:
# MOBILE_API_BASE_URL=http://api-admin.test/api/v1/mobile
