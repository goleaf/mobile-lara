{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "mobile-lara/monorepo",
    "type": "project",
    "description": "Monorepo shell for the Mobile Lara Admin/API service and NativePHP mobile client.",
    "license": "MIT",
    "scripts": {
        "api:build": "cd apps/api-admin && npm run build",
        "api:install": "cd apps/api-admin && composer install && npm install",
        "api:migrate": "cd apps/api-admin && php artisan migrate",
        "api:pint": "cd apps/api-admin && vendor/bin/pint --dirty --format agent",
        "api:test": "cd apps/api-admin && php artisan test",
        "build": [
            "@api:build",
            "@mobile:build"
        ],
        "install:apps": [
            "@api:install",
            "@mobile:install"
        ],
        "mobile:build": "cd apps/mobile-client && npm run build",
        "mobile:install": "cd apps/mobile-client && composer install && npm install",
        "mobile:migrate": "cd apps/mobile-client && php artisan migrate",
        "mobile:native:build": "cd apps/mobile-client && php artisan native:build --no-interaction",
        "mobile:native:jump": "cd apps/mobile-client && php artisan native:jump --no-interaction",
        "mobile:pint": "cd apps/mobile-client && vendor/bin/pint --dirty --format agent",
        "mobile:test": "cd apps/mobile-client && php artisan test",
        "pint": [
            "@api:pint",
            "@mobile:pint"
        ],
        "test": [
            "@api:test",
            "@mobile:test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
